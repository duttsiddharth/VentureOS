# ==========================================
# MultiVentures — Environment Variables
# Copy this to .env.local and fill in values
# ==========================================

# ── Anthropic ──────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── NextAuth ───────────────────────────────
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# ── Google OAuth ───────────────────────────
# https://console.cloud.google.com
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Supabase ───────────────────────────────
# https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Razorpay ───────────────────────────────
# Sign up free at https://razorpay.com — works in India instantly
# Get keys from: Dashboard → Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_...         # Use rzp_test_ for testing, rzp_live_ for production
RAZORPAY_KEY_SECRET=your-secret-key
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# Plan IDs — create in: Razorpay Dashboard → Subscriptions → Plans
RAZORPAY_PLAN_STARTER=plan_...       # ₹2,499/month — 10 analyses
RAZORPAY_PLAN_PRO=plan_...           # ₹6,599/month — unlimited
RAZORPAY_PLAN_AGENCY=plan_...        # ₹24,999/month — white-label

# ── App ────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
